# =====================================================================
# Konfigurasi deploy Jak Sanggar ke VPS Bizznet Neo Lite
# Salin file ini menjadi `.env` di folder yang sama, lalu isi nilainya.
#   cp .env.example .env
# Jangan commit file .env ke git (sudah ada di .gitignore deploy folder).
# =====================================================================

# IP atau hostname VPS Anda. Contoh: "103.150.xx.xx" atau "vps.namasaya.com"
VPS_HOST=ganti-dengan-ip-atau-hostname-vps

# Username SSH di VPS. Untuk Bizznet biasanya "root" atau user yang Anda buat.
VPS_USER=root

# Port SSH (default 22). Ubah jika Anda mengubahnya.
VPS_PORT=22

# Path tujuan di VPS tempat file web akan diletakkan.
# Sangat disarankan: /var/www/jak-sanggar
VPS_PATH=/var/www/jak-sanggar

# Domain utama yang sudah Anda arahkan ke IP VPS (DNS A record).
# Contoh: "jaksanggar.id" atau "app.namasaya.com"
DOMAIN=ganti-dengan-domain-anda

# Email untuk pendaftaran sertifikat HTTPS (Let's Encrypt).
LETSENCRYPT_EMAIL=email-anda@contoh.com
